<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="15dp"
    android:layout_marginVertical="5dp"
    android:background="@drawable/boton_redondeado"
    android:backgroundTint="#FFFFFF"
    android:elevation="2dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAsistenciaNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Alumno"
            android:textColor="#590000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/goldman_regular" />

        <TextView
            android:id="@+id/tvAsistenciaMatricula"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Matrícula: 12345678901"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/tvAsistenciaHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hora: 10:30 AM"
            android:textColor="#757575"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnCheckAsistio"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@android:drawable/checkbox_on_background"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Asistió"
        android:tint="#008000"
        android:layout_marginEnd="10dp" />

    <ImageButton
        android:id="@+id/btnCrossFalto"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@android:drawable/ic_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Faltó"
        android:tint="#FF0000" />

</LinearLayout>