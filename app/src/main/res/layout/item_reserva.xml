<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="15dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/boton_redondeado"
    android:backgroundTint="#FFFFFF"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tvNombreReserva"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Usuario: Juan Perez"
        android:textColor="#590000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/goldman_regular" />

    <TextView
        android:id="@+id/tvFechaReserva"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fecha: 12/12/2024"
        android:textColor="#000000"
        android:textSize="14sp"
        android:fontFamily="@font/inter_regular"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvHoraReserva"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hora: 10:30"
        android:textColor="#000000"
        android:textSize="14sp"
        android:fontFamily="@font/inter_regular"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/tvEstadoReserva"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estado: PENDIENTE"
        android:textColor="#757575"
        android:textSize="14sp"
        android:fontFamily="@font/inter_regular"
        android:textStyle="italic"
        android:layout_marginTop="4dp" />

</LinearLayout>
