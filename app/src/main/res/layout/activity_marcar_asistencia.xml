<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_main">

    <LinearLayout
        android:id="@+id/toolbarAsistencia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#33000000">

        <ImageButton
            android:id="@+id/btnBackToAdminMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:contentDescription="Regresar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MARCAR ASISTENCIAS"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="@font/goldman_regular"
            android:layout_marginStart="15dp" />
    </LinearLayout>

    <EditText
        android:id="@+id/etSearchAlumno"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbarAsistencia"
        android:layout_margin="16dp"
        android:hint="Buscar por matrícula o nombre..."
        android:background="@drawable/boton_redondeado"
        android:backgroundTint="#FFFFFF"
        android:padding="12dp"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="10dp"
        android:fontFamily="@font/inter_regular" />

    <ListView
        android:id="@+id/lvAsistencias"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/etSearchAlumno"
        android:paddingHorizontal="16dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/tvNoReservasHoy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No hay reservas pendientes para hoy."
        android:textColor="#000000"
        android:textSize="16sp"
        android:fontFamily="@font/inter_regular"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>