<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_main">

    <!-- CABECERA DE PERFIL -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="#33000000"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/imgUserProfile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/logo_upt"
            android:background="@drawable/boton_redondeado"
            android:backgroundTint="#FFFFFF"
            android:padding="5dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="15dp">

            <TextView
                android:id="@+id/tvWelcomeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Usuario"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="@font/goldman_regular" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver mi perfil"
                android:textColor="#D4AF37"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular" />
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENIDO SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplicaciones Disponibles"
                android:textColor="#000000"
                android:textSize="24sp"
                android:fontFamily="@font/goldman_regular"
                android:layout_marginBottom="20dp"
                android:gravity="center" />

            <!-- APP 1: GIMNASIO -->
            <LinearLayout
                android:id="@+id/itemGimnasio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/boton_redondeado"
                android:backgroundTint="#F5F5F5"
                android:padding="15dp"
                android:layout_marginBottom="15dp"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gimnasio UPT"
                        android:textColor="#590000"
                        android:textSize="18sp"
                        android:fontFamily="@font/goldman_regular" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gestiona tus rutinas y reserva tu lugar en el gimnasio."
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- APP 2 -->
            <LinearLayout
                android:id="@+id/itemReportes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:background="@drawable/boton_redondeado"
                android:backgroundTint="#F5F5F5"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="15dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo_report" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/goldman_regular"
                        android:text="UPT Report"
                        android:textColor="#590000"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_regular"
                        android:text="Aplicación para generar reportes de insidencias"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- APP 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/boton_redondeado"
                android:backgroundTint="#F5F5F5"
                android:padding="15dp"
                android:layout_marginBottom="15dp"
                android:elevation="4dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo_upt" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Servicios Escolares"
                        android:textColor="#590000"
                        android:textSize="18sp"
                        android:fontFamily="@font/goldman_regular" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consulta tus calificaciones y estatus académico."
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- APP 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/boton_redondeado"
                android:backgroundTint="#F5F5F5"
                android:padding="15dp"
                android:layout_marginBottom="15dp"
                android:elevation="4dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo_upt" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eventos UPT"
                        android:textColor="#590000"
                        android:textSize="18sp"
                        android:fontFamily="@font/goldman_regular" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entérate de las actividades culturales y deportivas."
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- APP 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/boton_redondeado"
                android:backgroundTint="#F5F5F5"
                android:padding="15dp"
                android:layout_marginBottom="15dp"
                android:elevation="4dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo_upt" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bolsa de Trabajo"
                        android:textColor="#590000"
                        android:textSize="18sp"
                        android:fontFamily="@font/goldman_regular" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Encuentra vacantes y oportunidades profesionales."
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>